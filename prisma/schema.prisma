generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id          String   @id @default(cuid())
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  groups        Group[]
  messages      ScheduledMessage[]
  users         User[]
  conversations WaConversation[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(OPERADOR)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  messages ScheduledMessage[]
}

enum Role {
  ADMIN
  OPERADOR
  CLIENTE
}

model Group {
  id           String   @id @default(cuid())
  remoteJid    String   @unique
  name         String
  participants Int      @default(0)
  active       Boolean  @default(true)
  syncedAt     DateTime @default(now())

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  messages      GroupMessage[]
  conversation  WaConversation?
}

model ScheduledMessage {
  id          String        @id @default(cuid())
  text        String
  mediaPath   String?
  mediaType   String?
  mediaName   String?
  scheduledAt DateTime
  status      MessageStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  sentAt      DateTime?

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  groups GroupMessage[]
  logs   MessageLog[]
}

model GroupMessage {
  groupId   String
  messageId String

  group   Group            @relation(fields: [groupId], references: [id])
  message ScheduledMessage @relation(fields: [messageId], references: [id])

  @@id([groupId, messageId])
}

enum MessageStatus {
  PENDING
  SENDING
  SENT
  FAILED
  CANCELLED
}

model MessageLog {
  id        String   @id @default(cuid())
  messageId String
  groupId   String
  groupName String
  status    String
  response  String?
  error     String?
  createdAt DateTime @default(now())

  message ScheduledMessage @relation(fields: [messageId], references: [id])
}

// Chat (estilo Chatwoot)

model WaConversation {
  id            String    @id @default(cuid())
  groupId       String    @unique
  clientId      String
  unreadCount   Int       @default(0)
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())

  group    Group      @relation(fields: [groupId], references: [id])
  client   Client     @relation(fields: [clientId], references: [id])
  messages WaMessage[]
}

model WaMessage {
  id             String   @id @default(cuid())
  conversationId String
  evolutionId    String?  @unique
  fromJid        String
  fromName       String?
  text           String?
  mediaUrl       String?
  mediaType      String?
  mediaName      String?
  isFromMe       Boolean  @default(false)
  timestamp      DateTime
  createdAt      DateTime @default(now())

  conversation WaConversation @relation(fields: [conversationId], references: [id])
}
