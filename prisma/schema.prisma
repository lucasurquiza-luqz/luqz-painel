generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id              String    @id @default(cuid())
  name            String
  description     String?
  active          Boolean   @default(true)
  clickupFolderId String?   @unique
  statusReason    String?
  statusChangedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // === Negócio do cliente (núcleo comum; o flexível por nicho vive no Contexto Vivo) ===
  legalName  String? // razão social
  cnpj       String?
  segment    String? // nicho / ramo de atuação
  website    String?
  instagram  String?
  region     String? // localização / praça
  logoUrl    String?

  // === Contrato (relação comercial LUQZ × cliente) ===
  product       String? // produto contratado (ex: AP360)
  contractValue Decimal?  @db.Decimal(12, 2) // MRR / valor mensal pago à LUQZ
  ticket        Decimal?  @db.Decimal(12, 2) // ticket médio do cliente
  billingCycle  String? // mensal, trimestral, projeto fechado...
  contractStart DateTime?
  renewalDate   DateTime?
  projectPhase  String? // fase do projeto (ex: Onboarding, Execução T3)

  groups              Group[]
  messages            ScheduledMessage[]
  users               User[]
  conversations       WaConversation[]
  contextSources      ContextSource[]
  contextItems        ContextItem[]
  contextSnapshots    ContextSnapshot[]
  statusHistory       ClientStatusHistory[]
  groupDailySummaries GroupDailySummary[]
  meetings            Meeting[]
  meetingSummaries    MeetingSummary[]
  teamCheckins        TeamCheckin[]
  nextActions         ClientNextAction[]
  contacts            ClientContact[]
  teamMembers         ClientTeamMember[]
  documents           ClientDocument[]
  resources           ClientResource[]
  mediaPlans          MediaPlan[]
  adAccounts          ClientAdAccount[]
  perfSnapshots       PerformanceSnapshot[]
  funnels             ClientFunnel[]
  projects            Project[]
  tasks               Task[]
}

// Cache de performance por cliente/mês. O painel lê daqui (instantâneo); um cron
// diário (+ botão "atualizar") refaz a leitura nas APIs de Ads e regrava o JSON.
model PerformanceSnapshot {
  id        String   @id @default(cuid())
  clientId  String
  month     String // AAAA-MM
  data      Json // objeto Performance serializado
  fetchedAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, month])
  @@index([clientId])
}

enum AdPlatform {
  META
  GOOGLE
  TOTAL
}

enum AdProvider {
  META
  GOOGLE
}

enum AdObjective {
  LEAD
  WHATSAPP
  ECOMMERCE
  CUSTOM
}

// Conta de anúncios por cliente. Meta: cada cliente tem a própria BM → token
// criptografado por cliente. Google: credencial central (MCC no env) → só o customer_id.
model ClientAdAccount {
  id          String     @id @default(cuid())
  clientId    String
  provider    AdProvider
  accountId   String // META: act_...  | GOOGLE: customer_id (sem traços)
  tokenEnc    String? // META: token criptografado. GOOGLE: null (usa MCC central)
  lastFour    String?
  // Config de conversão por cliente (funil flexível, MULTI-objetivo):
  objective     AdObjective   @default(LEAD) // legado (back-compat); usar objectives
  objectives    AdObjective[] @default([]) // vários funis na mesma conta (Lead + WhatsApp + Compras...)
  resultActions String[]      @default([]) // eventos custom (Meta action_type). Vazio = padrão dos objetivos.
  trackRevenue  Boolean       @default(false) // ecommerce: somar receita → ROAS
  updatedById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, provider])
}

// Funil = agrupamento de campanhas por regra de nome (1 funil → N campanhas).
model ClientFunnel {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  terms     String[] @default([]) // campanha pertence se o nome contém QUALQUER termo (case-insensitive)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

// Plano de mídia / metas por cliente e período (mês). Guarda os ALVOS;
// o realizado virá da integração de Ads (Bloco 2 — etapa seguinte).
model MediaPlan {
  id           String     @id @default(cuid())
  clientId     String
  month        String // período mensal "AAAA-MM"
  platform     AdPlatform @default(TOTAL)
  budget       Decimal?   @db.Decimal(12, 2)
  targetLeads  Int?
  targetCpa    Decimal?   @db.Decimal(12, 2)
  targetRoas   Decimal?   @db.Decimal(6, 2)
  targetTicket Decimal?   @db.Decimal(12, 2)
  notes        String?
  createdById  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User   @relation("MediaPlanCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([clientId, month, platform])
  @@index([clientId, month])
}

enum ResourceCategory {
  DRIVE
  ANALYTICS
  ADS
  SITE
  SOCIAL
  CREDENTIALS
  OTHER
}

// Links e recursos do cliente (Drive, GA4, Meta, Google Ads, site, social…).
model ClientResource {
  id        String           @id @default(cuid())
  clientId  String
  label     String
  url       String
  category  ResourceCategory @default(OTHER)
  notes     String?
  createdAt DateTime         @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, category])
}

enum DocumentCategory {
  PROPOSTA
  CONTRATO
  BRIEFING
  RELATORIO
  CRIATIVO
  ESTRATEGIA
  APRESENTACAO
  OUTRO
}

enum DocumentStatus {
  DRAFT
  APPROVED
}

enum DocVisibility {
  INTERNAL
  CLIENT
}

// Documento do cliente: arquivo no storage OU link externo (Drive etc.).
model ClientDocument {
  id           String           @id @default(cuid())
  clientId     String
  title        String
  category     DocumentCategory @default(OUTRO)
  status       DocumentStatus   @default(DRAFT)
  visibility   DocVisibility    @default(INTERNAL)
  fileUrl      String?
  fileName     String?
  fileType     String?
  externalUrl  String?
  notes        String?
  projectId    String? // atrelado a um projeto (opcional)
  uploadedById String
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  uploadedBy User     @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  approvedBy User?    @relation("DocumentApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([clientId, category])
  @@index([projectId])
}

// Contatos do lado do cliente (quem fala com a gente).
model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  role      String? // cargo / papel
  email     String?
  phone     String?
  isPrimary Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

enum LuqzTeamRole {
  GESTOR_PROJETO
  TRAFEGO
  CONTEUDO
  COMERCIAL
  DESIGN
  OUTRO
}

// Responsáveis LUQZ pela conta. userId opcional: nem todo membro tem login.
model ClientTeamMember {
  id        String       @id @default(cuid())
  clientId  String
  userId    String?
  name      String
  role      LuqzTeamRole @default(OUTRO)
  createdAt DateTime     @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User?  @relation("ClientTeamMemberUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([clientId])
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(OPERADOR)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  messages                  ScheduledMessage[]
  contextItemsCreated       ContextItem[]           @relation("ContextItemCreatedBy")
  contextItemsReviewed      ContextItem[]           @relation("ContextItemReviewedBy")
  contextSnapshots          ContextSnapshot[]       @relation("ContextSnapshotCompiledBy")
  clientStatusChanges       ClientStatusHistory[]   @relation("ClientStatusChangedBy")
  groupSummariesGenerated   GroupDailySummary[]     @relation("GroupDailySummaryGeneratedBy")
  groupSummaryItemsReviewed GroupDailySummaryItem[] @relation("GroupDailySummaryItemReviewedBy")
  aiCredentialsUpdated          AiCredential[]          @relation("AiCredentialUpdatedBy")
  aiModelConfigsUpdated         AiModelConfig[]         @relation("AiModelConfigUpdatedBy")
  meetingsCreated               Meeting[]               @relation("MeetingCreatedBy")
  meetingSummariesGenerated     MeetingSummary[]        @relation("MeetingSummaryGeneratedBy")
  meetingSummaryItemsReviewed   MeetingSummaryItem[]    @relation("MeetingSummaryItemReviewedBy")
  teamCheckins                  TeamCheckin[]           @relation("TeamCheckinAuthor")
  nextActionsResponsible        ClientNextAction[]      @relation("NextActionResponsible")
  nextActionsCreated            ClientNextAction[]      @relation("NextActionCreatedBy")
  assignedConversations         WaConversation[]        @relation("WaConversationAssignee")
  waTransfersFrom               WaConversationTransfer[] @relation("WaTransferFrom")
  waTransfersTo                 WaConversationTransfer[] @relation("WaTransferTo")
  waTransfersBy                 WaConversationTransfer[] @relation("WaTransferBy")
  clientTeamMemberships         ClientTeamMember[]       @relation("ClientTeamMemberUser")
  documentsUploaded             ClientDocument[]         @relation("DocumentUploadedBy")
  documentsApproved             ClientDocument[]         @relation("DocumentApprovedBy")
  mediaPlansCreated             MediaPlan[]              @relation("MediaPlanCreatedBy")
  tasksAssigned                 Task[]                   @relation("TaskAssignee")
}

enum Role {
  ADMIN
  OPERADOR
  CLIENTE
}

enum ClientStatusSource {
  MANUAL
  ROSTER_IMPORT
}

model ClientStatusHistory {
  id          String             @id @default(cuid())
  clientId    String
  active      Boolean
  reason      String?
  source      ClientStatusSource @default(MANUAL)
  changedById String
  changedAt   DateTime           @default(now())

  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  changedBy User   @relation("ClientStatusChangedBy", fields: [changedById], references: [id], onDelete: Restrict)

  @@index([clientId, changedAt])
}

model Group {
  id           String   @id @default(cuid())
  remoteJid    String   @unique
  name         String
  participants Int      @default(0)
  active       Boolean  @default(true)
  syncedAt     DateTime @default(now())

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  messages     GroupMessage[]
  conversation WaConversation?
}

model ScheduledMessage {
  id          String        @id @default(cuid())
  text        String
  mediaPath   String?
  mediaType   String?
  mediaName   String?
  scheduledAt DateTime
  status      MessageStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  sentAt      DateTime?

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  groups GroupMessage[]
  logs   MessageLog[]
}

model GroupMessage {
  groupId   String
  messageId String

  group   Group            @relation(fields: [groupId], references: [id])
  message ScheduledMessage @relation(fields: [messageId], references: [id])

  @@id([groupId, messageId])
}

enum MessageStatus {
  PENDING
  SENDING
  SENT
  FAILED
  CANCELLED
}

model MessageLog {
  id        String   @id @default(cuid())
  messageId String
  groupId   String
  groupName String
  status    String
  response  String?
  error     String?
  createdAt DateTime @default(now())

  message ScheduledMessage @relation(fields: [messageId], references: [id])
}

// Chat (estilo Chatwoot)

model WaConversation {
  id            String    @id @default(cuid())
  remoteJid     String    @unique
  isGroup       Boolean   @default(true)
  name          String
  groupId       String?   @unique
  clientId      String?
  unreadCount   Int       @default(0)
  lastMessageAt DateTime?
  assignedToId  String?
  createdAt     DateTime  @default(now())

  group          Group?                   @relation(fields: [groupId], references: [id])
  client         Client?                  @relation(fields: [clientId], references: [id])
  assignedTo     User?                    @relation("WaConversationAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages       WaMessage[]
  dailySummaries GroupDailySummary[]
  transfers      WaConversationTransfer[]

  @@index([assignedToId])
  @@index([clientId])
}

// Histórico de transferências de conversa entre membros do time.
model WaConversationTransfer {
  id             String   @id @default(cuid())
  conversationId String
  fromUserId     String?
  toUserId       String?
  byUserId       String
  note           String?
  createdAt      DateTime @default(now())

  conversation WaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  fromUser     User?          @relation("WaTransferFrom", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUser       User?          @relation("WaTransferTo", fields: [toUserId], references: [id], onDelete: SetNull)
  byUser       User           @relation("WaTransferBy", fields: [byUserId], references: [id], onDelete: Restrict)

  @@index([conversationId, createdAt])
}

model WaMessage {
  id             String   @id @default(cuid())
  conversationId String
  evolutionId    String?  @unique
  fromJid        String
  fromName       String?
  text           String?
  mediaUrl       String?
  mediaType      String?
  mediaName      String?
  isFromMe       Boolean  @default(false)
  timestamp      DateTime
  createdAt      DateTime @default(now())

  conversation WaConversation @relation(fields: [conversationId], references: [id])
}

enum NextActionStatus {
  OPEN
  DONE
  CANCELLED
}

// Proxima acao por cliente: quem age, o que e ate quando. Responde a pergunta
// central da torre de controle. Acoes concluidas viram historico (DONE/CANCELLED).
model ClientNextAction {
  id            String           @id @default(cuid())
  clientId      String
  description   String
  responsibleId String?
  dueAt         DateTime?
  status        NextActionStatus @default(OPEN)
  createdById   String
  createdAt     DateTime         @default(now())
  completedAt   DateTime?

  client      Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  responsible User?  @relation("NextActionResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  createdBy   User   @relation("NextActionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([clientId, status])
}

// Estado de runtime da integracao WhatsApp (singleton). Usado para diagnostico:
// ultimo estado de conexao e quando o ultimo webhook foi efetivamente recebido.
model WhatsAppRuntime {
  id                  String    @id @default("singleton")
  connectionState     String?
  lastWebhookAt       DateTime?
  lastMessageAt       DateTime?
  lastWebhookSecretOk Boolean? // último POST trouxe o secret correto? (verificação p/ ligar modo estrito)
  updatedAt           DateTime  @updatedAt
}

enum ContextDomain {
  DIRETRIZES
  OFERTA
  PERSONA
  TOM_DE_VOZ
  CLIENTE
  MEMORIA
  OPERACIONAL
}

enum ContextKind {
  RULE
  FACT
  DECISION
  GOAL
  HYPOTHESIS
  PERCEPTION
}

enum ContextStatus {
  PROPOSED
  ACTIVE
  SUPERSEDED
  REJECTED
}

enum ContextVisibility {
  INTERNAL
  CLIENT
}

enum ContextSourceType {
  FILE
  MANUAL
  GROUP
  MEETING
  INTEGRATION
}

model ContextSource {
  id         String            @id @default(cuid())
  clientId   String
  type       ContextSourceType
  label      String
  reference  String?
  checksum   String?
  capturedAt DateTime          @default(now())
  createdAt  DateTime          @default(now())

  client Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items  ContextItem[]

  @@index([clientId, type])
}

model ContextItem {
  id           String            @id @default(cuid())
  clientId     String
  sourceId     String
  domain       ContextDomain
  kind         ContextKind
  status       ContextStatus     @default(PROPOSED)
  visibility   ContextVisibility @default(INTERNAL)
  title        String
  content      String
  validFrom    DateTime?
  validUntil   DateTime?
  supersedesId String?
  createdById  String
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  client           Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  source           ContextSource          @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  createdBy        User                   @relation("ContextItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  reviewedBy       User?                  @relation("ContextItemReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  supersedes       ContextItem?           @relation("ContextItemHistory", fields: [supersedesId], references: [id], onDelete: SetNull)
  revisions        ContextItem[]          @relation("ContextItemHistory")
  snapshots        ContextSnapshotItem[]
  groupSummaryItem    GroupDailySummaryItem?
  meetingSummaryItem  MeetingSummaryItem?

  @@index([clientId, status, domain])
  @@index([sourceId])
  @@index([supersedesId])
}

model ContextSnapshot {
  id           String   @id @default(cuid())
  clientId     String
  version      Int
  content      Json
  checksum     String
  compiledById String
  compiledAt   DateTime @default(now())

  client     Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  compiledBy User                  @relation("ContextSnapshotCompiledBy", fields: [compiledById], references: [id], onDelete: Restrict)
  items      ContextSnapshotItem[]

  @@unique([clientId, version])
  @@index([clientId, compiledAt])
}

model ContextSnapshotItem {
  snapshotId String
  itemId     String
  position   Int

  snapshot ContextSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  item     ContextItem     @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@id([snapshotId, itemId])
  @@unique([snapshotId, position])
  @@index([itemId])
}

enum GroupSummaryStatus {
  DRAFT
  REVIEWED
}

// Leitura interpretativa da IA sobre o clima do relacionamento no dia.
// Sinaliza — nunca vira saúde oficial sem revisão humana.
enum GroupSummarySentiment {
  POSITIVE
  NEUTRAL
  CONCERN
  CRITICAL
}

enum GroupSummaryItemKind {
  DECISION
  COMMITMENT
  RISK
  PRAISE
  PENDING
}

enum GroupSummaryItemStatus {
  PROPOSED
  APPROVED
  REJECTED
  DISCARDED
}

model GroupDailySummary {
  id             String             @id @default(cuid())
  clientId       String
  conversationId String
  date           DateTime
  status         GroupSummaryStatus @default(DRAFT)
  messageCount   Int
  rawSummary     String
  // Leitura interpretativa da IA (clima do relacionamento). Opcionais para
  // não quebrar resumos antigos gerados antes da análise interpretativa.
  sentiment       GroupSummarySentiment?
  analysis        String?
  attentionPoints String[]               @default([])
  confidence      String?
  generatedByAi   Boolean                @default(false)
  generatedById   String?
  generatedAt     DateTime               @default(now())

  client       Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  conversation WaConversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  generatedBy  User?                   @relation("GroupDailySummaryGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull)
  items        GroupDailySummaryItem[]

  @@unique([conversationId, date])
  @@index([clientId, date])
}

model GroupDailySummaryItem {
  id               String                 @id @default(cuid())
  summaryId        String
  kind             GroupSummaryItemKind
  text             String
  responsible      String?
  sourceMessageIds String[]
  status           GroupSummaryItemStatus @default(PROPOSED)
  reviewedById     String?
  reviewedAt       DateTime?
  contextItemId    String?                @unique
  createdAt        DateTime               @default(now())

  summary     GroupDailySummary @relation(fields: [summaryId], references: [id], onDelete: Cascade)
  reviewedBy  User?             @relation("GroupDailySummaryItemReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  contextItem ContextItem?      @relation(fields: [contextItemId], references: [id], onDelete: SetNull)

  @@index([summaryId, status])
}

enum AiProvider {
  OPENAI
  ANTHROPIC
}

// Funções de IA do Dash — cada uma pode usar um provider/modelo diferente.
enum AiFunction {
  ASSISTANT
  GROUP_SUMMARY
  MEETING_SUMMARY
}

model AiModelConfig {
  id          String     @id @default(cuid())
  function    AiFunction @unique
  provider    AiProvider
  model       String
  updatedById String?
  updatedAt   DateTime   @updatedAt
  createdAt   DateTime   @default(now())

  updatedBy User? @relation("AiModelConfigUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
}

model AiCredential {
  id             String     @id @default(cuid())
  provider       AiProvider @unique
  label          String
  encryptedValue String
  lastFour       String
  updatedById    String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  updatedBy User @relation("AiCredentialUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
}


// === Meetings ===

enum MeetingKind {
  CALL
  IN_PERSON
  ASYNC
}

enum MeetingSummaryStatus {
  DRAFT
  REVIEWED
}

enum MeetingItemKind {
  DECISION
  COMMITMENT
  OBJECTION
  RISK
  NEXT_STEP
}

enum MeetingItemStatus {
  PROPOSED
  APPROVED
  REJECTED
  DISCARDED
}

model Meeting {
  id           String      @id @default(cuid())
  clientId     String
  title        String
  kind         MeetingKind
  date         DateTime
  participants String[]
  rawContent   String
  createdById  String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  client    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User           @relation("MeetingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  summary   MeetingSummary?

  @@index([clientId, date])
}

model MeetingSummary {
  id            String               @id @default(cuid())
  meetingId     String               @unique
  clientId      String
  status        MeetingSummaryStatus @default(DRAFT)
  rawSummary    String
  generatedById String
  generatedAt   DateTime             @default(now())

  meeting     Meeting              @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  client      Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  generatedBy User                 @relation("MeetingSummaryGeneratedBy", fields: [generatedById], references: [id], onDelete: Restrict)
  items       MeetingSummaryItem[]

  @@index([clientId])
}

model MeetingSummaryItem {
  id            String            @id @default(cuid())
  summaryId     String
  kind          MeetingItemKind
  text          String
  responsible   String?
  deadline      String?
  status        MeetingItemStatus @default(PROPOSED)
  reviewedById  String?
  reviewedAt    DateTime?
  contextItemId String?           @unique
  createdAt     DateTime          @default(now())

  summary     MeetingSummary @relation(fields: [summaryId], references: [id], onDelete: Cascade)
  reviewedBy  User?          @relation("MeetingSummaryItemReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  contextItem ContextItem?   @relation(fields: [contextItemId], references: [id], onDelete: SetNull)

  @@index([summaryId, status])
}

// === Team Check-in ===

enum TeamPerception {
  GREAT
  GOOD
  NEUTRAL
  CONCERN
  CRITICAL
}

model TeamCheckin {
  id            String         @id @default(cuid())
  clientId      String
  authorId      String
  perception    TeamPerception
  justification String
  validUntil    DateTime?
  createdAt     DateTime       @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author User   @relation("TeamCheckinAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([clientId, createdAt])
}

// === Módulo de Tarefas (ClickUp interno) — Fase 1: projetos + tarefas pontuais + histórico ===
enum ProjectStatus {
  ATIVO
  PAUSADO
  CONCLUIDO
  ARQUIVADO
}

enum TaskStatus {
  BACKLOG
  TODO
  DOING
  REVIEW
  DONE
}

enum TaskPriority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum ActivityEntity {
  TASK
  PROJECT
}

enum RecurFreq {
  DIARIA
  SEMANAL
  MENSAL
}

// Molde de tarefa recorrente: o cron gera instâncias de Task conforme a regra.
model TaskRecurrence {
  id          String       @id @default(cuid())
  projectId   String
  clientId    String?
  title       String
  description String?
  assigneeId  String?
  priority    TaskPriority @default(MEDIA)
  freq        RecurFreq    @default(SEMANAL)
  interval    Int          @default(1) // a cada N (dias/semanas/meses)
  weekday     Int? // 0-6 (SEMANAL) — legado, dia único
  weekdays    Int[]        @default([]) // 0-6 (SEMANAL personalizado, vários dias)
  dayOfMonth  Int? // 1-31 (MENSAL)
  active      Boolean      @default(true)
  nextRunAt   DateTime
  lastRunAt   DateTime?
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([active, nextRunAt])
  @@index([projectId])
}

enum ProjectKind {
  CONTEUDO
  TRAFEGO
  ONBOARDING
  WEB
  COMERCIAL
  INTERNO
  OUTRO
}

model Project {
  id          String        @id @default(cuid())
  clientId    String? // projeto de cliente ou interno (null)
  name        String
  description String?
  kind        ProjectKind   @default(OUTRO)
  notes       String? // documentação do projeto (markdown)
  objectives  String? // objetivos / metas do projeto
  links       Json? // hub de links/acessos: [{ label, url, category }]
  memberIds   String[]      @default([]) // pessoas envolvidas (ids de usuários)
  color       String?
  status      ProjectStatus @default(ATIVO)
  startDate   DateTime?
  dueDate     DateTime?
  ownerId     String? // responsável (scalar; nome resolvido pela equipe)
  order       Int           @default(0)
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client      Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks       Task[]
  documents   ClientDocument[]
  recurrences TaskRecurrence[]

  @@index([clientId])
}

model Task {
  id          String       @id @default(cuid())
  projectId   String?
  clientId    String? // denormalizado p/ filtrar por cliente
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIA)
  assigneeId   String?
  parentTaskId String? // subtarefa: aponta pra tarefa-mãe (mesmo projeto)
  recurrenceId String? // instância gerada por um molde recorrente
  dueDate      DateTime?
  completedAt  DateTime?
  order        Int          @default(0)
  createdById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignee User?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  parent   Task?    @relation("Subtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks Task[]   @relation("Subtasks")

  @@index([clientId])
  @@index([assigneeId])
  @@index([projectId])
  @@index([parentTaskId])
  @@index([status])
}

// Histórico genérico (tarefa OU projeto): criação, mudança de status, comentário, etc.
model Activity {
  id        String         @id @default(cuid())
  entity    ActivityEntity
  entityId  String
  userId    String?
  userName  String? // nome do autor no momento (evita join e sobrevive a remoção de usuário)
  type      String // CREATED | STATUS_CHANGED | ASSIGNED | DUE_CHANGED | COMMENTED | COMPLETED | REOPENED | EDITED
  payload   Json?
  createdAt DateTime       @default(now())

  @@index([entity, entityId, createdAt])
}
