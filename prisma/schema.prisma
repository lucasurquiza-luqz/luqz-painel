generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id              String    @id @default(cuid())
  name            String
  description     String?
  active          Boolean   @default(true)
  clickupFolderId String?   @unique
  statusReason    String?
  statusChangedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // === Perfil do negócio (Bloco 0.1 — cadastro completo) ===
  segment    String?
  website    String?
  instagram  String?
  region     String?
  logoUrl    String?

  // === Plano / contrato ===
  product       String? // produto contratado (ex: AP360)
  contractValue Decimal?  @db.Decimal(12, 2)
  billingCycle  String? // mensal, trimestral, projeto fechado...
  contractStart DateTime?
  renewalDate   DateTime?
  projectPhase  String? // fase do projeto (ex: Onboarding, Execução T3)

  groups              Group[]
  messages            ScheduledMessage[]
  users               User[]
  conversations       WaConversation[]
  contextSources      ContextSource[]
  contextItems        ContextItem[]
  contextSnapshots    ContextSnapshot[]
  statusHistory       ClientStatusHistory[]
  groupDailySummaries GroupDailySummary[]
  meetings            Meeting[]
  meetingSummaries    MeetingSummary[]
  teamCheckins        TeamCheckin[]
  nextActions         ClientNextAction[]
  contacts            ClientContact[]
  teamMembers         ClientTeamMember[]
  documents           ClientDocument[]
}

enum DocumentCategory {
  PROPOSTA
  CONTRATO
  BRIEFING
  RELATORIO
  CRIATIVO
  ESTRATEGIA
  APRESENTACAO
  OUTRO
}

enum DocumentStatus {
  DRAFT
  APPROVED
}

enum DocVisibility {
  INTERNAL
  CLIENT
}

// Documento do cliente: arquivo no storage OU link externo (Drive etc.).
model ClientDocument {
  id           String           @id @default(cuid())
  clientId     String
  title        String
  category     DocumentCategory @default(OUTRO)
  status       DocumentStatus   @default(DRAFT)
  visibility   DocVisibility    @default(INTERNAL)
  fileUrl      String?
  fileName     String?
  fileType     String?
  externalUrl  String?
  notes        String?
  uploadedById String
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  client     Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  approvedBy User?  @relation("DocumentApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([clientId, category])
}

// Contatos do lado do cliente (quem fala com a gente).
model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  role      String? // cargo / papel
  email     String?
  phone     String?
  isPrimary Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

enum LuqzTeamRole {
  GESTOR_PROJETO
  TRAFEGO
  CONTEUDO
  COMERCIAL
  DESIGN
  OUTRO
}

// Responsáveis LUQZ pela conta. userId opcional: nem todo membro tem login.
model ClientTeamMember {
  id        String       @id @default(cuid())
  clientId  String
  userId    String?
  name      String
  role      LuqzTeamRole @default(OUTRO)
  createdAt DateTime     @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User?  @relation("ClientTeamMemberUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([clientId])
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(OPERADOR)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  messages                  ScheduledMessage[]
  contextItemsCreated       ContextItem[]           @relation("ContextItemCreatedBy")
  contextItemsReviewed      ContextItem[]           @relation("ContextItemReviewedBy")
  contextSnapshots          ContextSnapshot[]       @relation("ContextSnapshotCompiledBy")
  clientStatusChanges       ClientStatusHistory[]   @relation("ClientStatusChangedBy")
  groupSummariesGenerated   GroupDailySummary[]     @relation("GroupDailySummaryGeneratedBy")
  groupSummaryItemsReviewed GroupDailySummaryItem[] @relation("GroupDailySummaryItemReviewedBy")
  aiCredentialsUpdated          AiCredential[]          @relation("AiCredentialUpdatedBy")
  meetingsCreated               Meeting[]               @relation("MeetingCreatedBy")
  meetingSummariesGenerated     MeetingSummary[]        @relation("MeetingSummaryGeneratedBy")
  meetingSummaryItemsReviewed   MeetingSummaryItem[]    @relation("MeetingSummaryItemReviewedBy")
  teamCheckins                  TeamCheckin[]           @relation("TeamCheckinAuthor")
  nextActionsResponsible        ClientNextAction[]      @relation("NextActionResponsible")
  nextActionsCreated            ClientNextAction[]      @relation("NextActionCreatedBy")
  assignedConversations         WaConversation[]        @relation("WaConversationAssignee")
  waTransfersFrom               WaConversationTransfer[] @relation("WaTransferFrom")
  waTransfersTo                 WaConversationTransfer[] @relation("WaTransferTo")
  waTransfersBy                 WaConversationTransfer[] @relation("WaTransferBy")
  clientTeamMemberships         ClientTeamMember[]       @relation("ClientTeamMemberUser")
  documentsUploaded             ClientDocument[]         @relation("DocumentUploadedBy")
  documentsApproved             ClientDocument[]         @relation("DocumentApprovedBy")
}

enum Role {
  ADMIN
  OPERADOR
  CLIENTE
}

enum ClientStatusSource {
  MANUAL
  ROSTER_IMPORT
}

model ClientStatusHistory {
  id          String             @id @default(cuid())
  clientId    String
  active      Boolean
  reason      String?
  source      ClientStatusSource @default(MANUAL)
  changedById String
  changedAt   DateTime           @default(now())

  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  changedBy User   @relation("ClientStatusChangedBy", fields: [changedById], references: [id], onDelete: Restrict)

  @@index([clientId, changedAt])
}

model Group {
  id           String   @id @default(cuid())
  remoteJid    String   @unique
  name         String
  participants Int      @default(0)
  active       Boolean  @default(true)
  syncedAt     DateTime @default(now())

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  messages     GroupMessage[]
  conversation WaConversation?
}

model ScheduledMessage {
  id          String        @id @default(cuid())
  text        String
  mediaPath   String?
  mediaType   String?
  mediaName   String?
  scheduledAt DateTime
  status      MessageStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  sentAt      DateTime?

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  groups GroupMessage[]
  logs   MessageLog[]
}

model GroupMessage {
  groupId   String
  messageId String

  group   Group            @relation(fields: [groupId], references: [id])
  message ScheduledMessage @relation(fields: [messageId], references: [id])

  @@id([groupId, messageId])
}

enum MessageStatus {
  PENDING
  SENDING
  SENT
  FAILED
  CANCELLED
}

model MessageLog {
  id        String   @id @default(cuid())
  messageId String
  groupId   String
  groupName String
  status    String
  response  String?
  error     String?
  createdAt DateTime @default(now())

  message ScheduledMessage @relation(fields: [messageId], references: [id])
}

// Chat (estilo Chatwoot)

model WaConversation {
  id            String    @id @default(cuid())
  remoteJid     String    @unique
  isGroup       Boolean   @default(true)
  name          String
  groupId       String?   @unique
  clientId      String?
  unreadCount   Int       @default(0)
  lastMessageAt DateTime?
  assignedToId  String?
  createdAt     DateTime  @default(now())

  group          Group?                   @relation(fields: [groupId], references: [id])
  client         Client?                  @relation(fields: [clientId], references: [id])
  assignedTo     User?                    @relation("WaConversationAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages       WaMessage[]
  dailySummaries GroupDailySummary[]
  transfers      WaConversationTransfer[]

  @@index([assignedToId])
  @@index([clientId])
}

// Histórico de transferências de conversa entre membros do time.
model WaConversationTransfer {
  id             String   @id @default(cuid())
  conversationId String
  fromUserId     String?
  toUserId       String?
  byUserId       String
  note           String?
  createdAt      DateTime @default(now())

  conversation WaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  fromUser     User?          @relation("WaTransferFrom", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUser       User?          @relation("WaTransferTo", fields: [toUserId], references: [id], onDelete: SetNull)
  byUser       User           @relation("WaTransferBy", fields: [byUserId], references: [id], onDelete: Restrict)

  @@index([conversationId, createdAt])
}

model WaMessage {
  id             String   @id @default(cuid())
  conversationId String
  evolutionId    String?  @unique
  fromJid        String
  fromName       String?
  text           String?
  mediaUrl       String?
  mediaType      String?
  mediaName      String?
  isFromMe       Boolean  @default(false)
  timestamp      DateTime
  createdAt      DateTime @default(now())

  conversation WaConversation @relation(fields: [conversationId], references: [id])
}

enum NextActionStatus {
  OPEN
  DONE
  CANCELLED
}

// Proxima acao por cliente: quem age, o que e ate quando. Responde a pergunta
// central da torre de controle. Acoes concluidas viram historico (DONE/CANCELLED).
model ClientNextAction {
  id            String           @id @default(cuid())
  clientId      String
  description   String
  responsibleId String?
  dueAt         DateTime?
  status        NextActionStatus @default(OPEN)
  createdById   String
  createdAt     DateTime         @default(now())
  completedAt   DateTime?

  client      Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  responsible User?  @relation("NextActionResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  createdBy   User   @relation("NextActionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([clientId, status])
}

// Estado de runtime da integracao WhatsApp (singleton). Usado para diagnostico:
// ultimo estado de conexao e quando o ultimo webhook foi efetivamente recebido.
model WhatsAppRuntime {
  id              String    @id @default("singleton")
  connectionState String?
  lastWebhookAt   DateTime?
  lastMessageAt   DateTime?
  updatedAt       DateTime  @updatedAt
}

enum ContextDomain {
  DIRETRIZES
  OFERTA
  PERSONA
  TOM_DE_VOZ
  CLIENTE
  MEMORIA
  OPERACIONAL
}

enum ContextKind {
  RULE
  FACT
  DECISION
  GOAL
  HYPOTHESIS
  PERCEPTION
}

enum ContextStatus {
  PROPOSED
  ACTIVE
  SUPERSEDED
  REJECTED
}

enum ContextVisibility {
  INTERNAL
  CLIENT
}

enum ContextSourceType {
  FILE
  MANUAL
  GROUP
  MEETING
  INTEGRATION
}

model ContextSource {
  id         String            @id @default(cuid())
  clientId   String
  type       ContextSourceType
  label      String
  reference  String?
  checksum   String?
  capturedAt DateTime          @default(now())
  createdAt  DateTime          @default(now())

  client Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items  ContextItem[]

  @@index([clientId, type])
}

model ContextItem {
  id           String            @id @default(cuid())
  clientId     String
  sourceId     String
  domain       ContextDomain
  kind         ContextKind
  status       ContextStatus     @default(PROPOSED)
  visibility   ContextVisibility @default(INTERNAL)
  title        String
  content      String
  validFrom    DateTime?
  validUntil   DateTime?
  supersedesId String?
  createdById  String
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  client           Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  source           ContextSource          @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  createdBy        User                   @relation("ContextItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  reviewedBy       User?                  @relation("ContextItemReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  supersedes       ContextItem?           @relation("ContextItemHistory", fields: [supersedesId], references: [id], onDelete: SetNull)
  revisions        ContextItem[]          @relation("ContextItemHistory")
  snapshots        ContextSnapshotItem[]
  groupSummaryItem    GroupDailySummaryItem?
  meetingSummaryItem  MeetingSummaryItem?

  @@index([clientId, status, domain])
  @@index([sourceId])
  @@index([supersedesId])
}

model ContextSnapshot {
  id           String   @id @default(cuid())
  clientId     String
  version      Int
  content      Json
  checksum     String
  compiledById String
  compiledAt   DateTime @default(now())

  client     Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  compiledBy User                  @relation("ContextSnapshotCompiledBy", fields: [compiledById], references: [id], onDelete: Restrict)
  items      ContextSnapshotItem[]

  @@unique([clientId, version])
  @@index([clientId, compiledAt])
}

model ContextSnapshotItem {
  snapshotId String
  itemId     String
  position   Int

  snapshot ContextSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  item     ContextItem     @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@id([snapshotId, itemId])
  @@unique([snapshotId, position])
  @@index([itemId])
}

enum GroupSummaryStatus {
  DRAFT
  REVIEWED
}

// Leitura interpretativa da IA sobre o clima do relacionamento no dia.
// Sinaliza — nunca vira saúde oficial sem revisão humana.
enum GroupSummarySentiment {
  POSITIVE
  NEUTRAL
  CONCERN
  CRITICAL
}

enum GroupSummaryItemKind {
  DECISION
  COMMITMENT
  RISK
  PRAISE
  PENDING
}

enum GroupSummaryItemStatus {
  PROPOSED
  APPROVED
  REJECTED
  DISCARDED
}

model GroupDailySummary {
  id             String             @id @default(cuid())
  clientId       String
  conversationId String
  date           DateTime
  status         GroupSummaryStatus @default(DRAFT)
  messageCount   Int
  rawSummary     String
  // Leitura interpretativa da IA (clima do relacionamento). Opcionais para
  // não quebrar resumos antigos gerados antes da análise interpretativa.
  sentiment       GroupSummarySentiment?
  analysis        String?
  attentionPoints String[]               @default([])
  confidence      String?
  generatedByAi   Boolean                @default(false)
  generatedById   String?
  generatedAt     DateTime               @default(now())

  client       Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  conversation WaConversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  generatedBy  User?                   @relation("GroupDailySummaryGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull)
  items        GroupDailySummaryItem[]

  @@unique([conversationId, date])
  @@index([clientId, date])
}

model GroupDailySummaryItem {
  id               String                 @id @default(cuid())
  summaryId        String
  kind             GroupSummaryItemKind
  text             String
  responsible      String?
  sourceMessageIds String[]
  status           GroupSummaryItemStatus @default(PROPOSED)
  reviewedById     String?
  reviewedAt       DateTime?
  contextItemId    String?                @unique
  createdAt        DateTime               @default(now())

  summary     GroupDailySummary @relation(fields: [summaryId], references: [id], onDelete: Cascade)
  reviewedBy  User?             @relation("GroupDailySummaryItemReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  contextItem ContextItem?      @relation(fields: [contextItemId], references: [id], onDelete: SetNull)

  @@index([summaryId, status])
}

enum AiProvider {
  OPENAI
}

model AiCredential {
  id             String     @id @default(cuid())
  provider       AiProvider @unique
  label          String
  encryptedValue String
  lastFour       String
  updatedById    String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  updatedBy User @relation("AiCredentialUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
}


// === Meetings ===

enum MeetingKind {
  CALL
  IN_PERSON
  ASYNC
}

enum MeetingSummaryStatus {
  DRAFT
  REVIEWED
}

enum MeetingItemKind {
  DECISION
  COMMITMENT
  OBJECTION
  RISK
  NEXT_STEP
}

enum MeetingItemStatus {
  PROPOSED
  APPROVED
  REJECTED
  DISCARDED
}

model Meeting {
  id           String      @id @default(cuid())
  clientId     String
  title        String
  kind         MeetingKind
  date         DateTime
  participants String[]
  rawContent   String
  createdById  String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  client    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User           @relation("MeetingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  summary   MeetingSummary?

  @@index([clientId, date])
}

model MeetingSummary {
  id            String               @id @default(cuid())
  meetingId     String               @unique
  clientId      String
  status        MeetingSummaryStatus @default(DRAFT)
  rawSummary    String
  generatedById String
  generatedAt   DateTime             @default(now())

  meeting     Meeting              @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  client      Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  generatedBy User                 @relation("MeetingSummaryGeneratedBy", fields: [generatedById], references: [id], onDelete: Restrict)
  items       MeetingSummaryItem[]

  @@index([clientId])
}

model MeetingSummaryItem {
  id            String            @id @default(cuid())
  summaryId     String
  kind          MeetingItemKind
  text          String
  responsible   String?
  deadline      String?
  status        MeetingItemStatus @default(PROPOSED)
  reviewedById  String?
  reviewedAt    DateTime?
  contextItemId String?           @unique
  createdAt     DateTime          @default(now())

  summary     MeetingSummary @relation(fields: [summaryId], references: [id], onDelete: Cascade)
  reviewedBy  User?          @relation("MeetingSummaryItemReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  contextItem ContextItem?   @relation(fields: [contextItemId], references: [id], onDelete: SetNull)

  @@index([summaryId, status])
}

// === Team Check-in ===

enum TeamPerception {
  GREAT
  GOOD
  NEUTRAL
  CONCERN
  CRITICAL
}

model TeamCheckin {
  id            String         @id @default(cuid())
  clientId      String
  authorId      String
  perception    TeamPerception
  justification String
  validUntil    DateTime?
  createdAt     DateTime       @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author User   @relation("TeamCheckinAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([clientId, createdAt])
}
