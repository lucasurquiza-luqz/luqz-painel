# Banco de dados PostgreSQL
DATABASE_URL="postgresql://luqz:senha@localhost:5432/luqz_painel"

# Segredo da sessão (gere uma string aleatória de 32+ chars)
SESSION_SECRET="troque-por-uma-string-aleatoria-muito-longa-aqui"

# Evolution API
EVOLUTION_URL="https://evolution.luqz.com.br"
EVOLUTION_API_KEY="sua-api-key-aqui"
EVOLUTION_INSTANCE="nome-da-instancia"

# URL pública do painel (para servir arquivos de mídia)
NEXT_PUBLIC_APP_URL="https://painel.luqz.com.br"

# Armazenamento de arquivos (anexos de tarefas, documentos de projeto/cliente).
# Sem isso, os uploads caem no disco local do container e SOMEM a cada deploy.
# Com MinIO/S3 os arquivos ficam persistentes e são servidos publicamente.
MINIO_ENDPOINT="http://minio:9000"              # endpoint da API S3 (interno do EasyPanel ou domínio)
MINIO_ACCESS_KEY="sua-access-key"
MINIO_SECRET_KEY="sua-secret-key"
MINIO_BUCKET="luqz-painel"                       # bucket (criado automaticamente se não existir)
MINIO_PUBLIC_URL="https://arquivos.luqz.com.br"  # base PÚBLICA p/ servir: {PUBLIC_URL}/{BUCKET}/{key}

# Chave interna do cron (segredo para proteger o endpoint)
CRON_SECRET="outro-segredo-aleatorio"

# Chave de serviço para automação operar a API (ex: agendar posts de Instagram
# pela linha /api/instagram/*). Enviar em: Authorization: Bearer <VALOR>.
# Sem ela, as rotas exigem sessão de usuário logado.
AUTOMATION_API_KEY="gere-uma-chave-aleatoria-forte"

# Secret do webhook Evolution — coloque na URL: ?secret=VALOR
# Ex: https://dash.luqz.com.br/api/webhook/evolution?secret=VALOR
EVOLUTION_WEBHOOK_SECRET=""
