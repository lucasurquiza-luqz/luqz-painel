# Banco de dados PostgreSQL
DATABASE_URL="postgresql://luqz:senha@localhost:5432/luqz_painel"

# Segredo da sessão (gere uma string aleatória de 32+ chars)
SESSION_SECRET="troque-por-uma-string-aleatoria-muito-longa-aqui"

# Evolution API
EVOLUTION_URL="https://evolution.luqz.com.br"
EVOLUTION_API_KEY="sua-api-key-aqui"
EVOLUTION_INSTANCE="nome-da-instancia"

# URL pública do painel (para servir arquivos de mídia)
NEXT_PUBLIC_APP_URL="https://painel.luqz.com.br"

# Chave interna do cron (segredo para proteger o endpoint)
CRON_SECRET="outro-segredo-aleatorio"

# Secret do webhook Evolution — coloque na URL: ?secret=VALOR
# Ex: https://dash.luqz.com.br/api/webhook/evolution?secret=VALOR
EVOLUTION_WEBHOOK_SECRET=""
